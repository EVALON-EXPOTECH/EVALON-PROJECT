CREATE DATABASE evalon_db;
USE evalon_db;

CREATE TABLE usuario (
	id_usuario INT PRIMARY KEY AUTO_INCREMENT,
	idioma VARCHAR(50),
	bio TEXT,
	username VARCHAR(100) UNIQUE NOT NULL,
	email VARCHAR(150) UNIQUE NOT NULL,
	senha_hash VARCHAR(255) NOT NULL,
	data_criacao DATETIME DEFAULT CURRENT_TIMESTAMP,
	status_conta VARCHAR(15)
);
 
 CREATE TABLE perfil (
	id_perfil INT PRIMARY KEY AUTO_INCREMENT,
	foto_perfil VARCHAR(255),
	banner VARCHAR(255),
	nivel_usuario INT DEFAULT 1,
	xp INT DEFAULT 0
);

CREATE TABLE tem (
	fk_usuario_id_usuario INT,
	fk_perfil_id_perfil INT,

	PRIMARY KEY (
		fk_usuario_id_usuario,
		fk_perfil_id_perfil
	),

	FOREIGN KEY (fk_usuario_id_usuario)
		REFERENCES usuario(id_usuario),

	FOREIGN KEY (fk_perfil_id_perfil)
		REFERENCES perfil(id_perfil)
);
 
 
 CREATE TABLE denuncia (
	id_denuncia INT PRIMARY KEY AUTO_INCREMENT,
	motivo VARCHAR(255),
	descricao TEXT,
	data_hora DATETIME,

	fk_usuario_id_usuario INT,

	FOREIGN KEY (fk_usuario_id_usuario)
		REFERENCES usuario(id_usuario)
); 

CREATE TABLE jogo (
	id_jogo INT PRIMARY KEY AUTO_INCREMENT,
	nome VARCHAR(150) NOT NULL,
	descricao TEXT,
	data_lancamento DATE,
	classificacao_etaria VARCHAR(50),
	score_comunidade DECIMAL(5,2),
	score_ia DECIMAL(5,2),
	total_avaliacoes INT DEFAULT 0
); 

CREATE TABLE avaliacao (
	id_avaliacao INT PRIMARY KEY AUTO_INCREMENT,
	comentario TEXT,
	nota_geral DECIMAL(3,1),
	data_avaliacao DATETIME DEFAULT CURRENT_TIMESTAMP,
	score_qualidade_ia DECIMAL(5,2),

	fk_jogo_id_jogo INT,
	fk_usuario_id_usuario INT,

	FOREIGN KEY (fk_jogo_id_jogo)
		REFERENCES jogo(id_jogo),

	FOREIGN KEY (fk_usuario_id_usuario)
		REFERENCES usuario(id_usuario)
); 

CREATE TABLE comentario_review (
	id_comentario INT PRIMARY KEY AUTO_INCREMENT,
	data_comentario DATETIME,
	texto TEXT,
	data_hora DATETIME,

	fk_avaliacao_id_avaliacao INT,
	fk_usuario_id_usuario INT,

	FOREIGN KEY (fk_avaliacao_id_avaliacao)
		REFERENCES avaliacao(id_avaliacao),

	FOREIGN KEY (fk_usuario_id_usuario)
		REFERENCES usuario(id_usuario)
);

CREATE TABLE recomendacao (
	id_recomendacao INT PRIMARY KEY AUTO_INCREMENT,
	score_relevancia DECIMAL(5,2),

	fk_usuario_id_usuario INT,

	FOREIGN KEY (fk_usuario_id_usuario)
		REFERENCES usuario(id_usuario)
);
 
 CREATE TABLE analise_ia (
	id_analise INT PRIMARY KEY AUTO_INCREMENT,
	sentimento_positivo_negativo VARCHAR(50),
	score_sentimento DECIMAL(5,2),
	resumo_gerado TEXT,
	data_analise DATETIME,

	fk_avaliacao_id_avaliacao INT,

	FOREIGN KEY (fk_avaliacao_id_avaliacao)
		REFERENCES avaliacao(id_avaliacao)
); 

CREATE TABLE moderacao_ia (
	id_moderacao INT PRIMARY KEY AUTO_INCREMENT,
	tipo_flag VARCHAR(100),
	score DECIMAL(5,2),
	acao VARCHAR(100),

	fk_avaliacao_id_avaliacao INT,

	FOREIGN KEY (fk_avaliacao_id_avaliacao)
		REFERENCES avaliacao(id_avaliacao)
);

CREATE TABLE modelo_ia (
	id_modelo INT PRIMARY KEY AUTO_INCREMENT,
	nome_modelo VARCHAR(100),

	fk_analise_id_analise INT,
	fk_recomendacao_id_recomendacao INT,

	FOREIGN KEY (fk_analise_id_analise)
		REFERENCES analise_ia(id_analise),

	FOREIGN KEY (fk_recomendacao_id_recomendacao)
		REFERENCES recomendacao(id_recomendacao)
);

CREATE TABLE genero (
    id_genero INT PRIMARY KEY AUTO_INCREMENT,
    nome VARCHAR(100)
);  

CREATE TABLE subgenero (
	id_subgenero INT PRIMARY KEY AUTO_INCREMENT,
	nome VARCHAR(100),

	fk_genero_id_genero INT,

	FOREIGN KEY (fk_genero_id_genero)
		REFERENCES genero(id_genero)
);
  
  
  CREATE TABLE tag (
	id_tag INT PRIMARY KEY AUTO_INCREMENT,
	nome VARCHAR(100)
); 

CREATE TABLE associado_a (
	fk_jogo_id_jogo INT,
	fk_tag_id_tag INT,

	PRIMARY KEY (
		fk_jogo_id_jogo,
		fk_tag_id_tag
	),

	FOREIGN KEY (fk_jogo_id_jogo)
		REFERENCES jogo(id_jogo),

	FOREIGN KEY (fk_tag_id_tag)
		REFERENCES tag(id_tag)
);  

CREATE TABLE plataforma (
	id_plataforma INT PRIMARY KEY AUTO_INCREMENT,
	nome VARCHAR(100) 
); 

CREATE TABLE disponivel_em (
	fk_jogo_id_jogo INT,
	fk_plataforma_id_plataforma INT,

	PRIMARY KEY (
		fk_jogo_id_jogo,
		fk_plataforma_id_plataforma
	),

	FOREIGN KEY (fk_jogo_id_jogo)
		REFERENCES jogo(id_jogo),

	FOREIGN KEY (fk_plataforma_id_plataforma)
		REFERENCES plataforma(id_plataforma)
); 

CREATE TABLE empresa (
	id_empresa INT PRIMARY KEY AUTO_INCREMENT,
	nome VARCHAR(150),
	tipo_dev_publisher VARCHAR(100)
);  

CREATE TABLE publica (
	fk_empresa_id_empresa INT,
	fk_jogo_id_jogo INT,

	PRIMARY KEY (
		fk_empresa_id_empresa,
		fk_jogo_id_jogo
	),

	FOREIGN KEY (fk_empresa_id_empresa)
		REFERENCES empresa(id_empresa),

	FOREIGN KEY (fk_jogo_id_jogo)
		REFERENCES jogo(id_jogo)
);  

CREATE TABLE desenvolve (
	fk_empresa_id_empresa INT,
	fk_jogo_id_jogo INT,

	PRIMARY KEY (
		fk_empresa_id_empresa,
		fk_jogo_id_jogo
	),

	FOREIGN KEY (fk_empresa_id_empresa)
		REFERENCES empresa(id_empresa),

	FOREIGN KEY (fk_jogo_id_jogo)
		REFERENCES jogo(id_jogo)
);

