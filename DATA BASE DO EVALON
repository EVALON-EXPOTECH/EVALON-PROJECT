SELECT 
    jogo.nome AS jogo,
    empresa.nome AS empresa,
    plataforma.nome AS plataforma

FROM jogo

JOIN desenvolve
ON jogo.id_jogo = desenvolve.fk_jogo_id_jogo

JOIN empresa
ON empresa.id_empresa = desenvolve.fk_empresa_id_empresa

JOIN disponivel_em
ON jogo.id_jogo = disponivel_em.fk_jogo_id_jogo

JOIN plataforma
ON plataforma.id_plataforma = disponivel_em.fk_plataforma_id_plataforma;

SELECT * FROM desenvolve;

SELECT jogo.nome, empresa.nome
FROM jogo
JOIN desenvolve
ON jogo.id_jogo = desenvolve.fk_jogo_id_jogo
JOIN empresa
ON empresa.id_empresa = desenvolve.fk_empresa_id_empresa;
