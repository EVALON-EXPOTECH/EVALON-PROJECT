def excluir_conta():
    
  cursorbd = db.cursor()

    
  id_usuario = int(input("ID de Usuário: "))
    
  cursorbd.execute("SELECT * FROM usuario where id_usuario =" + str(id_usuario)) 
  usuario = cursorbd.fetchall()
  
  
  if not usuario:
   
        print("Usuário não encontrado.")
            
  else:
      
   
      comando_perfil = "DELETE FROM perfil WHERE fk_usuario_id_usuario =" + str(id_usuario)
      cursorbd.execute(comando_perfil)
      db.commit()
      cursorbd = db.cursor()
      comando_denuncia = "DELETE FROM denuncia WHERE fk_usuario_id_usuario =" + str(id_usuario)
      cursorbd.execute(comando_denuncia)
      db.commit()
      cursorbd = db.cursor()
      comando_avaliacao = "DELETE FROM avaliacao WHERE fk_usuario_id_usuario =" + str(id_usuario)
      cursorbd.execute(comando_avaliacao)
      db.commit()
      cursorbd = db.cursor()
      comando_usuario = "DELETE FROM usuario WHERE id_usuario =" + str(id_usuario)
      cursorbd.execute(comando_usuario)
      db.commit()
      print(f"Usuário {id_usuario} deletado com sucesso!")
      cursorbd.close
      db.close


        
