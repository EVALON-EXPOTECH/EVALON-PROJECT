# Kaio — Alterar senha:
            
def altera_senha():
    
    username = input("Nome de usuário: ")
    senha_atual = input("Senha atual: ")
    nova_senha = input("Nova senha: ")

    verificar_sql = """
    SELECT * FROM usuario
    WHERE username = %s AND senha_hash = %s
    """

    cursor.execute(verificar_sql, (username, senha_atual))
    usuario = cursor.fetchone()

    if usuario:

        update_sql = """
        UPDATE usuario
        SET senha_hash = %s
        WHERE username = %s
        """

        cursor.execute(update_sql, (nova_senha, username))
        db.commit()

        print("Senha alterada com sucesso!")

    else:
        print("Usuário ou senha incorretos.")


    
    
    

