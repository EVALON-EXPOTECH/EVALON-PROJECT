def adi_jogo():

    nome = input("Título: ")
    descricao = input("Gênero: ")
    data_lancamento = (input("Data de Lançamento: "))
    classificacao_etaria = input("Classificação indicativa: ")
    score_comunidade = float(input("Pontuação da Comunidade: "))
    score_ia = float(input("Pontuação EVA: "))

    sql = """
    INSERT INTO jogo (nome, descricao, data_lancamento, classificacao_etaria, score_comunidade, score_ia)
