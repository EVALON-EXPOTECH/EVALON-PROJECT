def ver_avaliacoes():

   

    fk_jogo_id_jogo = int(input("Insira o ID do jogo: "))

    sql = """
    SELECT fk_jogo_id_jogo, fk_usuario_id_usuario, nota_geral, comentario, score_qualidade_ia
    FROM avaliacao
    WHERE fk_jogo_id_jogo = %s
    """

    cursor.execute(sql, (fk_jogo_id_jogo,))

    avaliacoes = cursor.fetchall()

    print("\n=== Avaliações ===")

    total = 0

    for avaliacao in avaliacoes:

        print(f"""
Autor: {avaliacao[0]}
Nota: {avaliacao[1]}
Comentário: {avaliacao[2]}
        """)

        total += avaliacao[1]

    if len(avaliacoes) > 0:

        average = total / len(avaliacoes)

        print(f"\nMédia: {average:.1f}")

    else:
        print("Sem avaliações.")
        
 
